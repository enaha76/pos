import { ScrollView, LineEdit } from "std-widgets.slint";

export struct ProductItem { id: string, name: string, price_label: string, color: color }
export struct CategoryChip { id: string, name: string, color: color }
export struct GridRow { a: ProductItem, b: ProductItem, c: ProductItem, count: int }
export struct CheckLine { item_id: string, name: string, qty: int, total_label: string, state: string }
export struct ReasonItem { id: string, label: string }
export struct ModItem { id: string, name: string, note: string, selected: bool }
export struct ZoneTab { id: string, name: string }
export struct TableSpot { id: string, label: string }
export struct ServerItem { id: string, name: string }
export struct CheckChip { id: string, label: string, active: bool }
export struct BarItem { label: string, amount: string, frac: float }
export struct VCItem { tag: string, label: string, count: int, amount: string }
export struct UnpaidItem { ticket: int, zone: string, server: string, reason: string, amount: string }
export struct CfgUser { id: string, name: string, role: string, active: bool }
export struct CfgServer { id: string, name: string, active: bool }
export struct CfgProduct { id: string, cat_id: string, cat_name: string, name: string, price: string, active: bool }
export struct CfgZone { id: string, name: string, mode: string, spot: string, active: bool }

component ProductCard inherits Rectangle {
    in property <ProductItem> product;
    callback clicked;
    horizontal-stretch: 1;
    height: 96px;
    border-radius: 12px;
    background: white;
    border-width: 1px;
    border-color: #c4ccd8;
    Rectangle { x: 0; y: 0; width: parent.width; height: 6px; background: product.color; }
    VerticalLayout {
        padding: 12px;
        padding-top: 16px;
        Text { text: product.name; font-size: 15px; font-weight: 700; wrap: word-wrap; }
        Rectangle { vertical-stretch: 1; }
        Text { text: product.price_label; font-size: 18px; font-weight: 800; color: product.color; }
    }
    TouchArea { clicked => { root.clicked(); } }
}

component Pill inherits Rectangle {
    in property <string> label;
    in property <color> dot;
    in property <bool> active;
    callback clicked;
    height: 40px;
    border-radius: 20px;
    background: active ? #2563eb : white;
    border-width: 1px;
    border-color: #c4ccd8;
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 16px;
        spacing: 8px;
        alignment: center;
        Rectangle { width: 12px; height: 12px; border-radius: 6px; background: dot; }
        Text { text: label; vertical-alignment: center; font-weight: 600; color: active ? white : #1b2230; }
    }
    TouchArea { clicked => { root.clicked(); } }
}

component Tab inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked;
    height: 40px;
    border-radius: 10px;
    background: active ? #2563eb : white;
    border-width: 1px;
    border-color: #c4ccd8;
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        Text { text: label; vertical-alignment: center; font-weight: 700; color: active ? white : #1b2230; }
    }
    TouchArea { clicked => { root.clicked(); } }
}

component Key inherits Rectangle {
    in property <string> label;
    in property <color> fill: #eef1f5;
    in property <color> ink: #1b2230;
    callback clicked;
    height: 56px;
    horizontal-stretch: 1;
    border-radius: 10px;
    background: fill;
    Text { text: label; font-size: 20px; font-weight: 700; color: ink; horizontal-alignment: center; vertical-alignment: center; }
    TouchArea { clicked => { root.clicked(); } }
}

component ActionBtn inherits Rectangle {
    in property <string> label;
    in property <color> fill;
    in property <bool> enabled: true;
    callback clicked;
    height: 52px;
    horizontal-stretch: 1;
    border-radius: 10px;
    background: enabled ? fill : #cbd5e1;
    Text { text: label; color: white; font-size: 16px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
    TouchArea { clicked => { if (root.enabled) { root.clicked(); } } }
}

component ReasonBtn inherits Rectangle {
    in property <string> label;
    callback clicked;
    height: 48px;
    border-radius: 8px;
    background: #eef1f5;
    Text { text: label; vertical-alignment: center; horizontal-alignment: center; }
    TouchArea { clicked => { root.clicked(); } }
}

component NavBtn inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked;
    height: 60px;
    border-radius: 12px;
    background: active ? #2563eb : transparent;
    Text { text: label; color: active ? white : #6a7384; font-size: 12px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; wrap: word-wrap; }
    TouchArea { clicked => { root.clicked(); } }
}

component StatTile inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <color> accent: #1b2230;
    height: 86px;
    horizontal-stretch: 1;
    border-radius: 12px;
    background: white;
    border-width: 1px;
    border-color: #c4ccd8;
    VerticalLayout {
        padding: 14px;
        Text { text: label; color: #6a7384; font-size: 13px; }
        Rectangle { vertical-stretch: 1; }
        Text { text: value; font-size: 24px; font-weight: 800; color: accent; }
    }
}

component BarRow inherits VerticalLayout {
    in property <string> label;
    in property <string> amount;
    in property <float> frac;
    spacing: 3px;
    HorizontalLayout {
        Text { text: label; font-weight: 600; horizontal-stretch: 1; }
        Text { text: amount; color: #6a7384; }
    }
    Rectangle {
        height: 8px; border-radius: 4px; background: #e6eaf0;
        Rectangle { x: 0; y: 0; height: parent.height; width: parent.width * frac; border-radius: 4px; background: #2563eb; }
    }
}

component Panel inherits VerticalLayout {
    in property <string> title;
    spacing: 8px;
    Text { text: title; font-size: 15px; font-weight: 800; }
    @children
}

export component MainWindow inherits Window {
    title: "Caisse — Café Adalya";
    preferred-width: 1120px;
    preferred-height: 740px;
    min-width: 960px;
    min-height: 640px;

    in property <bool> logged-in: false;
    in property <string> login-error;
    in property <string> operator-name;
    in property <string> operator-role;
    in property <string> currency: "MRU";
    in property <[ModItem]> mods;
    in property <[CategoryChip]> categories;
    in property <[GridRow]> grid;
    in property <[ZoneTab]> zones;
    in property <[TableSpot]> tables;
    in property <[ServerItem]> servers;
    in property <[CheckChip]> open-checks;
    in property <[CheckLine]> lines;
    in property <string> total-label;
    in property <int> ticket;
    in property <bool> has-check;
    in property <bool> can-send;
    in property <bool> can-pay;
    in property <string> status;
    in property <string> zone-name;
    in property <string> spot-label;
    in property <string> table-label;
    in property <string> server-name;
    in property <string> active-table-mode;
    in property <[ReasonItem]> void-reasons;
    in property <[ReasonItem]> comp-reasons;
    in property <[ReasonItem]> unpaid-reasons;
    // reports
    in property <string> rd-sales;
    in property <string> rd-paid;
    in property <string> rd-unpaid;
    in property <[UnpaidItem]> rd-unpaid-list;
    in property <[BarItem]> rd-by-server;
    in property <[VCItem]> rd-voidcomp;
    in property <string> rg-sales;
    in property <string> rg-paid;
    in property <string> rg-unpaid;
    in property <[BarItem]> rg-by-zone;
    in property <[BarItem]> rg-by-server;
    in property <[VCItem]> rg-voidcomp;
    in property <[CfgUser]> cfg-users;
    in property <[CfgServer]> cfg-servers;
    in property <[CfgProduct]> cfg-products;
    in property <[CfgZone]> cfg-zones;
    in-out property <string> route: "order";
    in-out property <string> cfg-prod-cat;
    in-out property <string> report-tab: "daily";
    in-out property <string> report-date;
    in-out property <string> cfg-tab: "users";
    in-out property <string> cfg-spot;
    in-out property <string> cfg-currency;
    in-out property <string> nu-name;
    in-out property <string> nu-role: "cashier";
    in-out property <string> nu-pin;
    in-out property <string> active-cat: "all";
    in-out property <string> active-zone;
    in-out property <string> active-table-id;
    in-out property <string> selected-item;
    in-out property <string> selected-state;
    in-out property <string> modal-kind;

    callback login(string);
    callback select-category(string);
    callback select-zone(string);
    callback set-table(string, string);
    callback pick-server(string);
    callback open-check(string);
    callback new-check();
    callback add-product(string);
    callback toggle-mod(string);
    callback confirm-mods();
    callback inc-line(string, int);
    callback send();
    callback apply-reason(string, string, string);
    callback pay(string);
    callback print-facture();
    callback refresh-reports();
    callback print-daily();
    callback config-refresh();
    callback save-user(string, string, string, bool);
    callback create-user();
    callback set-user-pin(string, string);
    callback save-server(string, string, bool);
    callback add-server();
    callback save-product(string, string, string, string, bool);
    callback create-product(string);
    callback save-zone(string, string, string, string, bool);
    callback create-zone();
    callback save-settings();
    callback logout();

    property <string> pin;

    // ===================== LOGIN =====================
    if !root.logged-in : Rectangle {
        background: #eef1f5;
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 320px;
                    height: 490px;
                    background: white;
                    border-radius: 16px;
                    border-width: 1px;
                    border-color: #c4ccd8;
                    VerticalLayout {
                        padding: 24px;
                        spacing: 10px;
                        Text { text: "Café Adalya"; font-size: 28px; font-weight: 800; horizontal-alignment: center; }
                        Text { text: "Caisse — connexion"; color: #6a7384; horizontal-alignment: center; }
                        Rectangle {
                            height: 52px;
                            border-radius: 10px;
                            background: #eef1f5;
                            Text { text: root.pin == "" ? "— — — —" : root.pin; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Text { text: root.login-error; color: #dc2626; horizontal-alignment: center; }
                        HorizontalLayout { spacing: 8px;
                            Key { label: "1"; clicked => { root.pin = root.pin + "1"; } }
                            Key { label: "2"; clicked => { root.pin = root.pin + "2"; } }
                            Key { label: "3"; clicked => { root.pin = root.pin + "3"; } }
                        }
                        HorizontalLayout { spacing: 8px;
                            Key { label: "4"; clicked => { root.pin = root.pin + "4"; } }
                            Key { label: "5"; clicked => { root.pin = root.pin + "5"; } }
                            Key { label: "6"; clicked => { root.pin = root.pin + "6"; } }
                        }
                        HorizontalLayout { spacing: 8px;
                            Key { label: "7"; clicked => { root.pin = root.pin + "7"; } }
                            Key { label: "8"; clicked => { root.pin = root.pin + "8"; } }
                            Key { label: "9"; clicked => { root.pin = root.pin + "9"; } }
                        }
                        HorizontalLayout { spacing: 8px;
                            Key { label: "C"; clicked => { root.pin = ""; } }
                            Key { label: "0"; clicked => { root.pin = root.pin + "0"; } }
                            Key { label: "OK"; fill: #2563eb; ink: white; clicked => { root.login(root.pin); root.pin = ""; } }
                        }
                    }
                }
            }
        }
    }

    // ===================== APP (nav rail + content) =====================
    if root.logged-in : Rectangle {
        background: #eef1f5;
        HorizontalLayout {
            // ---- nav rail ----
            Rectangle {
                width: 96px;
                background: white;
                VerticalLayout {
                    padding: 10px;
                    spacing: 8px;
                    NavBtn { label: "Commande"; active: root.route == "order"; clicked => { root.route = "order"; } }
                    if root.operator-role == "admin" : NavBtn { label: "Rapports"; active: root.route == "reports"; clicked => { root.route = "reports"; root.refresh-reports(); } }
                    if root.operator-role == "admin" : NavBtn { label: "Config"; active: root.route == "config"; clicked => { root.route = "config"; root.config-refresh(); } }
                    Rectangle { vertical-stretch: 1; }
                    Text { text: root.operator-name; color: #6a7384; font-size: 11px; horizontal-alignment: center; wrap: word-wrap; }
                    NavBtn { label: "Quitter"; clicked => { root.logout(); } }
                }
            }

            // ---- content ----
            Rectangle {
                horizontal-stretch: 1;

                // ===== ORDER SCREEN =====
                if root.route == "order" : VerticalLayout {
                    // open checks bar
                    Rectangle {
                        height: 56px;
                        background: white;
                        HorizontalLayout {
                            padding: 8px;
                            spacing: 8px;
                            ScrollView {
                                horizontal-stretch: 1;
                                height: 40px;
                                HorizontalLayout {
                                    spacing: 8px;
                                    for c in root.open-checks : Rectangle {
                                        height: 38px;
                                        border-radius: 10px;
                                        background: c.active ? #2563eb : #eef1f5;
                                        HorizontalLayout {
                                            padding-left: 12px;
                                            padding-right: 12px;
                                            Text { text: c.label; vertical-alignment: center; font-weight: 600; color: c.active ? white : #1b2230; }
                                        }
                                        TouchArea { clicked => { root.open-check(c.id); } }
                                    }
                                }
                            }
                            Rectangle {
                                width: 160px;
                                height: 38px;
                                border-radius: 10px;
                                background: #16a34a;
                                Text { text: "+ Nouvelle note"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                TouchArea { clicked => { root.new-check(); } }
                            }
                        }
                    }

                    HorizontalLayout {
                        // left: zones + categories + grid
                        VerticalLayout {
                            horizontal-stretch: 1;
                            padding: 12px;
                            spacing: 10px;
                            ScrollView {
                                height: 44px;
                                HorizontalLayout {
                                    spacing: 8px;
                                    for z in root.zones : Tab {
                                        label: z.name;
                                        active: root.active-zone == z.id;
                                        clicked => { root.select-zone(z.id); }
                                    }
                                }
                            }
                            ScrollView {
                                height: 44px;
                                HorizontalLayout {
                                    spacing: 8px;
                                    Pill { label: "Tout"; dot: #6a7384; active: root.active-cat == "all"; clicked => { root.active-cat = "all"; root.select-category("all"); } }
                                    for c in root.categories : Pill {
                                        label: c.name;
                                        dot: c.color;
                                        active: root.active-cat == c.id;
                                        clicked => { root.active-cat = c.id; root.select-category(c.id); }
                                    }
                                }
                            }
                            ScrollView {
                                vertical-stretch: 1;
                                VerticalLayout {
                                    spacing: 10px;
                                    for row in root.grid : HorizontalLayout {
                                        spacing: 10px;
                                        ProductCard { product: row.a; clicked => { root.add-product(row.a.id); } }
                                        if row.count >= 2 : ProductCard { product: row.b; clicked => { root.add-product(row.b.id); } }
                                        if row.count < 2 : Rectangle { horizontal-stretch: 1; }
                                        if row.count >= 3 : ProductCard { product: row.c; clicked => { root.add-product(row.c.id); } }
                                        if row.count < 3 : Rectangle { horizontal-stretch: 1; }
                                    }
                                }
                            }
                        }

                        // right: check panel
                        Rectangle {
                            width: 380px;
                            background: white;
                            VerticalLayout {
                                padding: 16px;
                                spacing: 8px;
                                Text {
                                    text: root.has-check ? "Ticket nº \{root.ticket}" : "Nouvelle note";
                                    font-size: 18px; font-weight: 800; color: #d97706;
                                }
                                HorizontalLayout {
                                    spacing: 6px;
                                    Text { text: root.zone-name == "" ? "Aucune zone" : root.zone-name; color: #6a7384; vertical-alignment: center; }
                                    if root.table-label != "" : Text { text: "· \{root.spot-label} \{root.table-label}"; color: #6a7384; vertical-alignment: center; }
                                }
                                Rectangle {
                                    height: 44px; border-radius: 10px; background: #eef1f5; border-width: 1px; border-color: #c4ccd8;
                                    HorizontalLayout {
                                        padding-left: 12px; padding-right: 12px; spacing: 8px;
                                        Text { text: "Serveur"; color: #6a7384; vertical-alignment: center; }
                                        Text { text: root.server-name; font-weight: 700; vertical-alignment: center; horizontal-stretch: 1; }
                                        Text { text: "▾"; color: #6a7384; vertical-alignment: center; }
                                    }
                                    TouchArea { clicked => { root.modal-kind = "server"; } }
                                }
                                if root.active-table-mode == "free" : LineEdit {
                                    placeholder-text: "Numéro (optionnel), Entrée pour valider";
                                    text: root.table-label;
                                    accepted(t) => { root.set-table("", t); }
                                }
                                if root.active-table-mode == "fixed" : ScrollView {
                                    height: 50px;
                                    HorizontalLayout {
                                        spacing: 6px;
                                        for t in root.tables : Rectangle {
                                            width: 50px; height: 44px; border-radius: 8px;
                                            background: root.active-table-id == t.id ? #2563eb : #eef1f5;
                                            Text { text: t.label; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; color: root.active-table-id == t.id ? white : #1b2230; }
                                            TouchArea { clicked => { root.set-table(t.id, ""); } }
                                        }
                                    }
                                }
                                ScrollView {
                                    vertical-stretch: 1;
                                    VerticalLayout {
                                        spacing: 4px;
                                        for l in root.lines : Rectangle {
                                            height: 54px;
                                            border-radius: 8px;
                                            background: root.selected-item == l.item_id ? #e6eaf0 : white;
                                            border-width: root.selected-item == l.item_id ? 2px : 1px;
                                            border-color: root.selected-item == l.item_id ? #2563eb : #eef1f5;
                                            HorizontalLayout {
                                                padding: 6px;
                                                spacing: 10px;
                                                Rectangle {
                                                    width: 34px; height: 34px; border-radius: 8px; background: #e6eaf0;
                                                    Text { text: "\{l.qty}"; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                                }
                                                VerticalLayout {
                                                    horizontal-stretch: 1;
                                                    Text { text: l.name; font-weight: 600; }
                                                    Text {
                                                        font-size: 12px;
                                                        text: l.state == "HELD" ? "En attente" : l.state == "SENT" ? "Envoyé" : l.state == "VOID" ? "Annulé" : "Offert";
                                                        color: l.state == "HELD" ? #d97706 : l.state == "SENT" ? #16a34a : l.state == "VOID" ? #dc2626 : #7c3aed;
                                                    }
                                                }
                                                Text {
                                                    text: l.total_label; vertical-alignment: center; font-weight: 700;
                                                    color: (l.state == "VOID" || l.state == "COMP") ? #6a7384 : #1b2230;
                                                }
                                            }
                                            TouchArea { clicked => { root.selected-item = l.item_id; root.selected-state = l.state; } }
                                        }
                                    }
                                }
                                if root.selected-state == "HELD" : HorizontalLayout {
                                    spacing: 8px;
                                    Rectangle { width: 48px; height: 44px; border-radius: 8px; background: #e6eaf0;
                                        Text { text: "-"; font-size: 22px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea { clicked => { root.inc-line(root.selected-item, -1); } }
                                    }
                                    Rectangle { width: 48px; height: 44px; border-radius: 8px; background: #e6eaf0;
                                        Text { text: "+"; font-size: 22px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea { clicked => { root.inc-line(root.selected-item, 1); } }
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    Rectangle { width: 110px; height: 44px; border-radius: 8px; background: #dc2626;
                                        Text { text: "Annuler"; color: white; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea { clicked => { root.modal-kind = "void"; } }
                                    }
                                }
                                if root.selected-state == "SENT" : Rectangle {
                                    height: 44px; border-radius: 8px; background: #7c3aed;
                                    Text { text: "Offrir"; color: white; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { clicked => { root.modal-kind = "comp"; } }
                                }
                                Rectangle { height: 1px; background: #c4ccd8; }
                                HorizontalLayout {
                                    Text { text: "TOTAL"; font-size: 20px; font-weight: 800; horizontal-stretch: 1; vertical-alignment: center; }
                                    Text { text: root.total-label; font-size: 22px; font-weight: 800; }
                                }
                                ActionBtn { label: "Envoyer en cuisine"; fill: #16a34a; enabled: root.can-send; clicked => { root.send(); } }
                                Rectangle {
                                    height: 44px; border-radius: 10px; background: #e6eaf0;
                                    Text { text: "Imprimer la facture"; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                    TouchArea { clicked => { root.print-facture(); } }
                                }
                                HorizontalLayout {
                                    spacing: 10px;
                                    ActionBtn { label: "Espèces"; fill: #16a34a; enabled: root.can-pay; clicked => { root.pay("Espèces"); } }
                                    ActionBtn { label: "Portefeuille"; fill: #2563eb; enabled: root.can-pay; clicked => { root.pay("Portefeuille"); } }
                                }
                                if root.has-check : Rectangle {
                                    height: 34px;
                                    Text { text: "Clôturer impayé"; color: #6a7384; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { clicked => { root.modal-kind = "unpaid"; } }
                                }
                                Text { text: root.status; color: #16a34a; horizontal-alignment: center; wrap: word-wrap; }
                            }
                        }
                    }
                }

                // ===== REPORTS SCREEN =====
                if root.route == "reports" : VerticalLayout {
                    padding: 16px;
                    spacing: 12px;
                    HorizontalLayout {
                        spacing: 10px;
                        Text { text: "Rapports"; font-size: 22px; font-weight: 800; vertical-alignment: center; }
                        Tab { label: "Aujourd'hui"; active: root.report-tab == "daily"; clicked => { root.report-tab = "daily"; } }
                        Tab { label: "Global"; active: root.report-tab == "global"; clicked => { root.report-tab = "global"; } }
                        Rectangle { horizontal-stretch: 1; }
                        Rectangle {
                            width: 120px; height: 40px; border-radius: 10px; background: #eef1f5; border-width: 1px; border-color: #c4ccd8;
                            Text { text: "Actualiser"; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                            TouchArea { clicked => { root.refresh-reports(); } }
                        }
                        if root.report-tab == "daily" : Rectangle {
                            width: 180px; height: 40px; border-radius: 10px; background: #2563eb;
                            Text { text: "Clôturer la journée"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                            TouchArea { clicked => { root.print-daily(); } }
                        }
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 14px;

                            if root.report-tab == "daily" : VerticalLayout {
                                spacing: 14px;
                                HorizontalLayout {
                                    spacing: 10px;
                                    StatTile { label: "Ventes"; value: root.rd-sales; accent: #16a34a; }
                                    StatTile { label: "Notes payées"; value: root.rd-paid; }
                                    StatTile { label: "Impayés"; value: root.rd-unpaid; accent: #dc2626; }
                                }
                                Panel {
                                    title: "Impayés — qui est responsable";
                                    for u in root.rd-unpaid-list : Rectangle {
                                        height: 54px; border-radius: 10px; background: #fdecec; border-width: 1px; border-color: #f5c2c2;
                                        HorizontalLayout {
                                            padding: 8px; spacing: 8px;
                                            VerticalLayout {
                                                horizontal-stretch: 1;
                                                Text { text: "Ticket nº \{u.ticket} · \{u.zone}"; font-weight: 700; }
                                                Text { text: u.reason; font-size: 12px; color: #6a7384; }
                                            }
                                            VerticalLayout {
                                                Text { text: u.amount; font-weight: 800; color: #dc2626; horizontal-alignment: right; }
                                                Text { text: u.server; font-size: 12px; color: #6a7384; horizontal-alignment: right; }
                                            }
                                        }
                                    }
                                }
                                Panel {
                                    title: "Ventes par serveur";
                                    for b in root.rd-by-server : BarRow { label: b.label; amount: b.amount; frac: b.frac; }
                                }
                                Panel {
                                    title: "Annulations & offerts";
                                    for v in root.rd-voidcomp : HorizontalLayout {
                                        Text { text: "\{v.tag} · \{v.label} ×\{v.count}"; horizontal-stretch: 1; }
                                        Text { text: v.amount; color: #6a7384; }
                                    }
                                }
                            }

                            if root.report-tab == "global" : VerticalLayout {
                                spacing: 14px;
                                HorizontalLayout {
                                    spacing: 10px;
                                    StatTile { label: "Ventes"; value: root.rg-sales; accent: #16a34a; }
                                    StatTile { label: "Notes payées"; value: root.rg-paid; }
                                    StatTile { label: "Impayés"; value: root.rg-unpaid; accent: #dc2626; }
                                }
                                Panel {
                                    title: "Ventes par zone";
                                    for b in root.rg-by-zone : BarRow { label: b.label; amount: b.amount; frac: b.frac; }
                                }
                                Panel {
                                    title: "Ventes par serveur";
                                    for b in root.rg-by-server : BarRow { label: b.label; amount: b.amount; frac: b.frac; }
                                }
                                Panel {
                                    title: "Annulations & offerts";
                                    for v in root.rg-voidcomp : HorizontalLayout {
                                        Text { text: "\{v.tag} · \{v.label} ×\{v.count}"; horizontal-stretch: 1; }
                                        Text { text: v.amount; color: #6a7384; }
                                    }
                                }
                            }
                        }
                    }
                }

                // ===== CONFIGURATION SCREEN (admin) =====
                if root.route == "config" : VerticalLayout {
                    padding: 16px;
                    spacing: 12px;
                    HorizontalLayout {
                        spacing: 10px;
                        Text { text: "Configuration"; font-size: 22px; font-weight: 800; vertical-alignment: center; }
                        Tab { label: "Utilisateurs"; active: root.cfg-tab == "users"; clicked => { root.cfg-tab = "users"; } }
                        Tab { label: "Serveurs"; active: root.cfg-tab == "servers"; clicked => { root.cfg-tab = "servers"; } }
                        Tab { label: "Produits"; active: root.cfg-tab == "products"; clicked => { root.cfg-tab = "products"; } }
                        Tab { label: "Zones"; active: root.cfg-tab == "zones"; clicked => { root.cfg-tab = "zones"; } }
                        Tab { label: "Réglages"; active: root.cfg-tab == "settings"; clicked => { root.cfg-tab = "settings"; } }
                    }
                    Text { text: root.status; color: #dc2626; horizontal-alignment: center; }
                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 10px;

                            if root.cfg-tab == "users" : VerticalLayout {
                                spacing: 10px;
                                Rectangle {
                                    background: white; border-radius: 12px; border-width: 1px; border-color: #c4ccd8;
                                    VerticalLayout {
                                        padding: 12px; spacing: 8px;
                                        Text { text: "Ajouter un utilisateur"; font-weight: 800; }
                                        HorizontalLayout {
                                            spacing: 8px;
                                            LineEdit { placeholder-text: "Nom"; text: root.nu-name; edited(t) => { root.nu-name = t; } }
                                            Rectangle {
                                                width: 130px; height: 34px; border-radius: 8px; background: #eef1f5;
                                                Text { text: root.nu-role == "admin" ? "Propriétaire" : "Caissier"; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                                TouchArea { clicked => { root.nu-role = root.nu-role == "admin" ? "cashier" : "admin"; } }
                                            }
                                            LineEdit { placeholder-text: "Code"; text: root.nu-pin; edited(t) => { root.nu-pin = t; } }
                                            Rectangle {
                                                width: 100px; height: 34px; border-radius: 8px; background: #16a34a;
                                                Text { text: "Ajouter"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                                TouchArea { clicked => { root.create-user(); } }
                                            }
                                        }
                                    }
                                }
                                for u in root.cfg-users : Rectangle {
                                    background: white; border-radius: 10px; border-width: 1px; border-color: #c4ccd8;
                                    opacity: u.active ? 1.0 : 0.55;
                                    HorizontalLayout {
                                        padding: 10px; spacing: 8px;
                                        LineEdit { text: u.name; accepted(t) => { root.save-user(u.id, t, u.role, u.active); } }
                                        Rectangle {
                                            width: 130px; height: 40px; border-radius: 8px; background: #eef1f5;
                                            Text { text: u.role == "admin" ? "Propriétaire" : "Caissier"; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                            TouchArea { clicked => { root.save-user(u.id, u.name, u.role == "admin" ? "cashier" : "admin", u.active); } }
                                        }
                                        Rectangle {
                                            width: 100px; height: 40px; border-radius: 8px; background: u.active ? #16a34a : #cbd5e1;
                                            Text { text: u.active ? "Actif" : "Inactif"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                            TouchArea { clicked => { root.save-user(u.id, u.name, u.role, !u.active); } }
                                        }
                                        LineEdit { placeholder-text: "Nouveau code"; accepted(t) => { root.set-user-pin(u.id, t); } }
                                    }
                                }
                            }

                            if root.cfg-tab == "servers" : VerticalLayout {
                                spacing: 10px;
                                Rectangle {
                                    width: 200px; height: 40px; border-radius: 10px; background: #16a34a;
                                    Text { text: "+ Ajouter un serveur"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                    TouchArea { clicked => { root.add-server(); } }
                                }
                                for s in root.cfg-servers : Rectangle {
                                    background: white; border-radius: 10px; border-width: 1px; border-color: #c4ccd8;
                                    opacity: s.active ? 1.0 : 0.55;
                                    HorizontalLayout {
                                        padding: 10px; spacing: 8px;
                                        LineEdit { text: s.name; accepted(t) => { root.save-server(s.id, t, s.active); } }
                                        Rectangle {
                                            width: 110px; height: 40px; border-radius: 8px; background: s.active ? #16a34a : #cbd5e1;
                                            Text { text: s.active ? "Actif" : "Inactif"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                            TouchArea { clicked => { root.save-server(s.id, s.name, !s.active); } }
                                        }
                                    }
                                }
                            }

                            if root.cfg-tab == "products" : VerticalLayout {
                                spacing: 10px;
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text { text: "Ajouter dans :"; vertical-alignment: center; font-weight: 700; }
                                    ScrollView {
                                        horizontal-stretch: 1; height: 44px;
                                        HorizontalLayout {
                                            spacing: 8px;
                                            for c in root.categories : Pill { label: c.name; dot: c.color; active: root.cfg-prod-cat == c.id; clicked => { root.cfg-prod-cat = c.id; } }
                                        }
                                    }
                                    Rectangle {
                                        width: 120px; height: 40px; border-radius: 10px; background: #16a34a;
                                        Text { text: "+ Ajouter"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                        TouchArea { clicked => { root.create-product(root.cfg-prod-cat); } }
                                    }
                                }
                                for p in root.cfg-products : Rectangle {
                                    background: white; border-radius: 10px; border-width: 1px; border-color: #c4ccd8;
                                    opacity: p.active ? 1.0 : 0.55;
                                    HorizontalLayout {
                                        padding: 10px; spacing: 8px;
                                        Text { text: p.cat_name; width: 120px; color: #6a7384; vertical-alignment: center; }
                                        LineEdit { text: p.name; accepted(t) => { root.save-product(p.id, p.cat_id, t, p.price, p.active); } }
                                        LineEdit { width: 90px; text: p.price; accepted(t) => { root.save-product(p.id, p.cat_id, p.name, t, p.active); } }
                                        Text { text: root.currency; vertical-alignment: center; color: #6a7384; }
                                        Rectangle {
                                            width: 100px; height: 40px; border-radius: 8px; background: p.active ? #16a34a : #cbd5e1;
                                            Text { text: p.active ? "Visible" : "Masqué"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                            TouchArea { clicked => { root.save-product(p.id, p.cat_id, p.name, p.price, !p.active); } }
                                        }
                                    }
                                }
                            }

                            if root.cfg-tab == "zones" : VerticalLayout {
                                spacing: 10px;
                                Rectangle {
                                    width: 180px; height: 40px; border-radius: 10px; background: #16a34a;
                                    Text { text: "+ Ajouter une zone"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                    TouchArea { clicked => { root.create-zone(); } }
                                }
                                for z in root.cfg-zones : Rectangle {
                                    background: white; border-radius: 10px; border-width: 1px; border-color: #c4ccd8;
                                    opacity: z.active ? 1.0 : 0.55;
                                    VerticalLayout {
                                        padding: 10px; spacing: 8px;
                                        HorizontalLayout {
                                            spacing: 8px;
                                            LineEdit { text: z.name; accepted(t) => { root.save-zone(z.id, t, z.mode, z.spot, z.active); } }
                                            Rectangle {
                                                width: 110px; height: 40px; border-radius: 8px; background: z.active ? #16a34a : #cbd5e1;
                                                Text { text: z.active ? "Active" : "Retirée"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                                TouchArea { clicked => { root.save-zone(z.id, z.name, z.mode, z.spot, !z.active); } }
                                            }
                                        }
                                        HorizontalLayout {
                                            spacing: 6px;
                                            Rectangle { width: 90px; height: 36px; border-radius: 8px; background: z.mode == "none" ? #2563eb : #eef1f5;
                                                Text { text: "Aucune"; horizontal-alignment: center; vertical-alignment: center; font-weight: 600; color: z.mode == "none" ? white : #1b2230; }
                                                TouchArea { clicked => { root.save-zone(z.id, z.name, "none", z.spot, z.active); } }
                                            }
                                            Rectangle { width: 90px; height: 36px; border-radius: 8px; background: z.mode == "free" ? #2563eb : #eef1f5;
                                                Text { text: "Libre"; horizontal-alignment: center; vertical-alignment: center; font-weight: 600; color: z.mode == "free" ? white : #1b2230; }
                                                TouchArea { clicked => { root.save-zone(z.id, z.name, "free", z.spot, z.active); } }
                                            }
                                            Rectangle { width: 90px; height: 36px; border-radius: 8px; background: z.mode == "fixed" ? #2563eb : #eef1f5;
                                                Text { text: "Fixe"; horizontal-alignment: center; vertical-alignment: center; font-weight: 600; color: z.mode == "fixed" ? white : #1b2230; }
                                                TouchArea { clicked => { root.save-zone(z.id, z.name, "fixed", z.spot, z.active); } }
                                            }
                                            LineEdit { placeholder-text: "Libellé (Table/Place…)"; text: z.spot; accepted(t) => { root.save-zone(z.id, z.name, z.mode, t, z.active); } }
                                        }
                                    }
                                }
                            }

                            if root.cfg-tab == "settings" : VerticalLayout {
                                spacing: 10px;
                                Rectangle {
                                    background: white; border-radius: 12px; border-width: 1px; border-color: #c4ccd8;
                                    VerticalLayout {
                                        padding: 14px; spacing: 10px;
                                        Text { text: "Libellé d'emplacement par défaut"; font-weight: 700; }
                                        LineEdit { text: root.cfg-spot; edited(t) => { root.cfg-spot = t; } }
                                        Text { text: "Devise"; font-weight: 700; }
                                        LineEdit { text: root.cfg-currency; edited(t) => { root.cfg-currency = t; } }
                                        Rectangle {
                                            width: 140px; height: 40px; border-radius: 10px; background: #2563eb;
                                            Text { text: "Enregistrer"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                            TouchArea { clicked => { root.save-settings(); } }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ===================== MODAL =====================
    if root.modal-kind != "" : Rectangle {
        background: #00000088;
        TouchArea { clicked => { root.modal-kind = ""; } }
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 380px;
                    height: 460px;
                    background: white;
                    border-radius: 14px;
                    TouchArea {}
                    VerticalLayout {
                        padding: 18px;
                        spacing: 8px;
                        Text {
                            font-size: 18px; font-weight: 800;
                            text: root.modal-kind == "server" ? "Assigner un serveur"
                                : root.modal-kind == "mods" ? "Options"
                                : root.modal-kind == "void" ? "Annuler l'article"
                                : root.modal-kind == "comp" ? "Offrir l'article"
                                : "Clôturer la note impayée";
                        }
                        ScrollView {
                            vertical-stretch: 1;
                            VerticalLayout {
                                spacing: 6px;
                                if root.modal-kind == "server" : VerticalLayout {
                                    spacing: 6px;
                                    for s in root.servers : ReasonBtn { label: s.name; clicked => { root.pick-server(s.id); root.modal-kind = ""; } }
                                }
                                if root.modal-kind == "mods" : VerticalLayout {
                                    spacing: 6px;
                                    for m in root.mods : Rectangle {
                                        height: 48px; border-radius: 8px;
                                        background: m.selected ? #2563eb : #eef1f5;
                                        HorizontalLayout {
                                            padding-left: 12px; padding-right: 12px; spacing: 8px;
                                            Text { text: m.name; vertical-alignment: center; horizontal-stretch: 1; font-weight: 600; color: m.selected ? white : #1b2230; }
                                            Text { text: m.note; vertical-alignment: center; color: m.selected ? white : #6a7384; }
                                        }
                                        TouchArea { clicked => { root.toggle-mod(m.id); } }
                                    }
                                }
                                if root.modal-kind == "void" : VerticalLayout {
                                    spacing: 6px;
                                    for rz in root.void-reasons : ReasonBtn { label: rz.label; clicked => { root.apply-reason("void", root.selected-item, rz.id); root.modal-kind = ""; } }
                                }
                                if root.modal-kind == "comp" : VerticalLayout {
                                    spacing: 6px;
                                    for rz in root.comp-reasons : ReasonBtn { label: rz.label; clicked => { root.apply-reason("comp", root.selected-item, rz.id); root.modal-kind = ""; } }
                                }
                                if root.modal-kind == "unpaid" : VerticalLayout {
                                    spacing: 6px;
                                    for rz in root.unpaid-reasons : ReasonBtn { label: rz.label; clicked => { root.apply-reason("unpaid", root.selected-item, rz.id); root.modal-kind = ""; } }
                                }
                            }
                        }
                        Rectangle {
                            height: 46px; border-radius: 8px;
                            background: root.modal-kind == "mods" ? #16a34a : #e6eaf0;
                            Text {
                                text: root.modal-kind == "mods" ? "Ajouter" : "Fermer";
                                color: root.modal-kind == "mods" ? white : #1b2230;
                                horizontal-alignment: center; vertical-alignment: center; font-weight: 700;
                            }
                            TouchArea { clicked => { if (root.modal-kind == "mods") { root.confirm-mods(); } else { root.modal-kind = ""; } } }
                        }
                    }
                }
            }
        }
    }
}
