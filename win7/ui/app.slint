import { ScrollView, LineEdit } from "std-widgets.slint";

export struct ProductItem { id: string, name: string, price: int, color: color }
export struct CategoryChip { id: string, name: string, color: color }
export struct GridRow { a: ProductItem, b: ProductItem, c: ProductItem, count: int }
export struct CheckLine { item_id: string, name: string, qty: int, total: int, state: string }
export struct ReasonItem { id: string, label: string }
export struct ZoneTab { id: string, name: string }
export struct TableSpot { id: string, label: string }
export struct ServerItem { id: string, name: string }
export struct CheckChip { id: string, label: string, active: bool }

component ProductCard inherits Rectangle {
    in property <ProductItem> product;
    in property <string> currency;
    callback clicked;
    horizontal-stretch: 1;
    height: 96px;
    border-radius: 12px;
    background: white;
    border-width: 1px;
    border-color: #c4ccd8;
    Rectangle { x: 0; y: 0; width: parent.width; height: 6px; background: product.color; }
    VerticalLayout {
        padding: 12px;
        padding-top: 16px;
        Text { text: product.name; font-size: 15px; font-weight: 700; wrap: word-wrap; }
        Rectangle { vertical-stretch: 1; }
        Text { text: "\{product.price} \{root.currency}"; font-size: 18px; font-weight: 800; color: product.color; }
    }
    TouchArea { clicked => { root.clicked(); } }
}

component Pill inherits Rectangle {
    in property <string> label;
    in property <color> dot;
    in property <bool> active;
    callback clicked;
    height: 40px;
    border-radius: 20px;
    background: active ? #2563eb : white;
    border-width: 1px;
    border-color: #c4ccd8;
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 16px;
        spacing: 8px;
        alignment: center;
        Rectangle { width: 12px; height: 12px; border-radius: 6px; background: dot; }
        Text { text: label; vertical-alignment: center; font-weight: 600; color: active ? white : #1b2230; }
    }
    TouchArea { clicked => { root.clicked(); } }
}

// A rounded tab with no dot (zones).
component Tab inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked;
    height: 40px;
    border-radius: 10px;
    background: active ? #2563eb : white;
    border-width: 1px;
    border-color: #c4ccd8;
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        Text { text: label; vertical-alignment: center; font-weight: 700; color: active ? white : #1b2230; }
    }
    TouchArea { clicked => { root.clicked(); } }
}

component Key inherits Rectangle {
    in property <string> label;
    in property <color> fill: #eef1f5;
    in property <color> ink: #1b2230;
    callback clicked;
    height: 56px;
    horizontal-stretch: 1;
    border-radius: 10px;
    background: fill;
    Text { text: label; font-size: 20px; font-weight: 700; color: ink; horizontal-alignment: center; vertical-alignment: center; }
    TouchArea { clicked => { root.clicked(); } }
}

component ActionBtn inherits Rectangle {
    in property <string> label;
    in property <color> fill;
    in property <bool> enabled: true;
    callback clicked;
    height: 52px;
    horizontal-stretch: 1;
    border-radius: 10px;
    background: enabled ? fill : #cbd5e1;
    Text { text: label; color: white; font-size: 16px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
    TouchArea { clicked => { if (root.enabled) { root.clicked(); } } }
}

component ReasonBtn inherits Rectangle {
    in property <string> label;
    callback clicked;
    height: 48px;
    border-radius: 8px;
    background: #eef1f5;
    Text { text: label; vertical-alignment: center; horizontal-alignment: center; }
    TouchArea { clicked => { root.clicked(); } }
}

export component MainWindow inherits Window {
    title: "Caisse — Café Adalya";
    preferred-width: 1080px;
    preferred-height: 720px;
    min-width: 940px;
    min-height: 620px;

    in property <bool> logged-in: false;
    in property <string> login-error;
    in property <string> operator-name;
    in property <string> currency: "MRU";
    in property <[CategoryChip]> categories;
    in property <[GridRow]> grid;
    in property <[ZoneTab]> zones;
    in property <[TableSpot]> tables;
    in property <[ServerItem]> servers;
    in property <[CheckChip]> open-checks;
    in property <[CheckLine]> lines;
    in property <int> total;
    in property <int> ticket;
    in property <bool> has-check;
    in property <bool> can-send;
    in property <bool> can-pay;
    in property <string> status;
    in property <string> zone-name;
    in property <string> spot-label;
    in property <string> table-label;
    in property <string> server-name;
    in property <string> active-table-mode;
    in property <[ReasonItem]> void-reasons;
    in property <[ReasonItem]> comp-reasons;
    in property <[ReasonItem]> unpaid-reasons;
    in-out property <string> active-cat: "all";
    in-out property <string> active-zone;
    in-out property <string> active-table-id;
    in-out property <string> selected-item;
    in-out property <string> selected-state;
    in-out property <string> modal-kind;

    callback login(string);
    callback select-category(string);
    callback select-zone(string);
    callback set-table(string, string);
    callback pick-server(string);
    callback open-check(string);
    callback new-check();
    callback add-product(string);
    callback inc-line(string, int);
    callback send();
    callback apply-reason(string, string, string);
    callback pay(string);
    callback print-facture();
    callback logout();

    property <string> pin;

    // ===================== LOGIN =====================
    if !root.logged-in : Rectangle {
        background: #eef1f5;
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 320px;
                    height: 490px;
                    background: white;
                    border-radius: 16px;
                    border-width: 1px;
                    border-color: #c4ccd8;
                    VerticalLayout {
                        padding: 24px;
                        spacing: 10px;
                        Text { text: "Café Adalya"; font-size: 28px; font-weight: 800; horizontal-alignment: center; }
                        Text { text: "Caisse — connexion"; color: #6a7384; horizontal-alignment: center; }
                        Rectangle {
                            height: 52px;
                            border-radius: 10px;
                            background: #eef1f5;
                            Text { text: root.pin == "" ? "— — — —" : root.pin; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Text { text: root.login-error; color: #dc2626; horizontal-alignment: center; }
                        HorizontalLayout { spacing: 8px;
                            Key { label: "1"; clicked => { root.pin = root.pin + "1"; } }
                            Key { label: "2"; clicked => { root.pin = root.pin + "2"; } }
                            Key { label: "3"; clicked => { root.pin = root.pin + "3"; } }
                        }
                        HorizontalLayout { spacing: 8px;
                            Key { label: "4"; clicked => { root.pin = root.pin + "4"; } }
                            Key { label: "5"; clicked => { root.pin = root.pin + "5"; } }
                            Key { label: "6"; clicked => { root.pin = root.pin + "6"; } }
                        }
                        HorizontalLayout { spacing: 8px;
                            Key { label: "7"; clicked => { root.pin = root.pin + "7"; } }
                            Key { label: "8"; clicked => { root.pin = root.pin + "8"; } }
                            Key { label: "9"; clicked => { root.pin = root.pin + "9"; } }
                        }
                        HorizontalLayout { spacing: 8px;
                            Key { label: "C"; clicked => { root.pin = ""; } }
                            Key { label: "0"; clicked => { root.pin = root.pin + "0"; } }
                            Key { label: "OK"; fill: #2563eb; ink: white; clicked => { root.login(root.pin); root.pin = ""; } }
                        }
                    }
                }
            }
        }
    }

    // ===================== MAIN =====================
    if root.logged-in : Rectangle {
        background: #eef1f5;
        VerticalLayout {
            // top bar
            Rectangle {
                height: 56px;
                background: white;
                HorizontalLayout {
                    padding: 14px;
                    spacing: 12px;
                    Text { text: "Café Adalya — Caisse"; font-size: 18px; font-weight: 800; vertical-alignment: center; }
                    Rectangle { horizontal-stretch: 1; }
                    Text { text: root.operator-name; color: #6a7384; vertical-alignment: center; }
                    Rectangle {
                        width: 130px;
                        height: 36px;
                        border-radius: 10px;
                        background: #eef1f5;
                        Text { text: "Déconnexion"; horizontal-alignment: center; vertical-alignment: center; font-weight: 600; }
                        TouchArea { clicked => { root.logout(); } }
                    }
                }
            }

            // open checks bar
            Rectangle {
                height: 56px;
                background: white;
                border-width: 1px;
                border-color: #eef1f5;
                HorizontalLayout {
                    padding: 8px;
                    spacing: 8px;
                    ScrollView {
                        horizontal-stretch: 1;
                        height: 40px;
                        HorizontalLayout {
                            spacing: 8px;
                            for c in root.open-checks : Rectangle {
                                height: 38px;
                                border-radius: 10px;
                                background: c.active ? #2563eb : #eef1f5;
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    Text { text: c.label; vertical-alignment: center; font-weight: 600; color: c.active ? white : #1b2230; }
                                }
                                TouchArea { clicked => { root.open-check(c.id); } }
                            }
                        }
                    }
                    Rectangle {
                        width: 160px;
                        height: 38px;
                        border-radius: 10px;
                        background: #16a34a;
                        Text { text: "+ Nouvelle note"; color: white; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                        TouchArea { clicked => { root.new-check(); } }
                    }
                }
            }

            HorizontalLayout {
                // ---- left: zones + categories + product grid ----
                VerticalLayout {
                    horizontal-stretch: 1;
                    padding: 12px;
                    spacing: 10px;
                    ScrollView {
                        height: 44px;
                        HorizontalLayout {
                            spacing: 8px;
                            for z in root.zones : Tab {
                                label: z.name;
                                active: root.active-zone == z.id;
                                clicked => { root.select-zone(z.id); }
                            }
                        }
                    }
                    ScrollView {
                        height: 44px;
                        HorizontalLayout {
                            spacing: 8px;
                            Pill { label: "Tout"; dot: #6a7384; active: root.active-cat == "all"; clicked => { root.active-cat = "all"; root.select-category("all"); } }
                            for c in root.categories : Pill {
                                label: c.name;
                                dot: c.color;
                                active: root.active-cat == c.id;
                                clicked => { root.active-cat = c.id; root.select-category(c.id); }
                            }
                        }
                    }
                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 10px;
                            for row in root.grid : HorizontalLayout {
                                spacing: 10px;
                                ProductCard { product: row.a; currency: root.currency; clicked => { root.add-product(row.a.id); } }
                                if row.count >= 2 : ProductCard { product: row.b; currency: root.currency; clicked => { root.add-product(row.b.id); } }
                                if row.count < 2 : Rectangle { horizontal-stretch: 1; }
                                if row.count >= 3 : ProductCard { product: row.c; currency: root.currency; clicked => { root.add-product(row.c.id); } }
                                if row.count < 3 : Rectangle { horizontal-stretch: 1; }
                            }
                        }
                    }
                }

                // ---- right: check panel ----
                Rectangle {
                    width: 380px;
                    background: white;
                    VerticalLayout {
                        padding: 16px;
                        spacing: 8px;
                        Text {
                            text: root.has-check ? "Ticket nº \{root.ticket}" : "Nouvelle note";
                            font-size: 18px; font-weight: 800; color: #d97706;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Text { text: root.zone-name == "" ? "Aucune zone" : root.zone-name; color: #6a7384; vertical-alignment: center; }
                            if root.table-label != "" : Text { text: "· \{root.spot-label} \{root.table-label}"; color: #6a7384; vertical-alignment: center; }
                        }

                        // server assignment
                        Rectangle {
                            height: 44px; border-radius: 10px; background: #eef1f5; border-width: 1px; border-color: #c4ccd8;
                            HorizontalLayout {
                                padding-left: 12px; padding-right: 12px; spacing: 8px;
                                Text { text: "Serveur"; color: #6a7384; vertical-alignment: center; }
                                Text { text: root.server-name; font-weight: 700; vertical-alignment: center; horizontal-stretch: 1; }
                                Text { text: "▾"; color: #6a7384; vertical-alignment: center; }
                            }
                            TouchArea { clicked => { root.modal-kind = "server"; } }
                        }

                        // table selector
                        if root.active-table-mode == "free" : LineEdit {
                            placeholder-text: "Numéro (optionnel), Entrée pour valider";
                            text: root.table-label;
                            accepted(t) => { root.set-table("", t); }
                        }
                        if root.active-table-mode == "fixed" : ScrollView {
                            height: 50px;
                            HorizontalLayout {
                                spacing: 6px;
                                for t in root.tables : Rectangle {
                                    width: 50px; height: 44px; border-radius: 8px;
                                    background: root.active-table-id == t.id ? #2563eb : #eef1f5;
                                    Text { text: t.label; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; color: root.active-table-id == t.id ? white : #1b2230; }
                                    TouchArea { clicked => { root.set-table(t.id, ""); } }
                                }
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;
                            VerticalLayout {
                                spacing: 4px;
                                for l in root.lines : Rectangle {
                                    height: 54px;
                                    border-radius: 8px;
                                    background: root.selected-item == l.item_id ? #e6eaf0 : white;
                                    border-width: root.selected-item == l.item_id ? 2px : 1px;
                                    border-color: root.selected-item == l.item_id ? #2563eb : #eef1f5;
                                    HorizontalLayout {
                                        padding: 6px;
                                        spacing: 10px;
                                        Rectangle {
                                            width: 34px; height: 34px; border-radius: 8px; background: #e6eaf0;
                                            Text { text: "\{l.qty}"; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                                        }
                                        VerticalLayout {
                                            horizontal-stretch: 1;
                                            Text { text: l.name; font-weight: 600; }
                                            Text {
                                                font-size: 12px;
                                                text: l.state == "HELD" ? "En attente" : l.state == "SENT" ? "Envoyé" : l.state == "VOID" ? "Annulé" : "Offert";
                                                color: l.state == "HELD" ? #d97706 : l.state == "SENT" ? #16a34a : l.state == "VOID" ? #dc2626 : #7c3aed;
                                            }
                                        }
                                        Text {
                                            text: "\{l.total} \{root.currency}"; vertical-alignment: center; font-weight: 700;
                                            color: (l.state == "VOID" || l.state == "COMP") ? #6a7384 : #1b2230;
                                        }
                                    }
                                    TouchArea { clicked => { root.selected-item = l.item_id; root.selected-state = l.state; } }
                                }
                            }
                        }

                        if root.selected-state == "HELD" : HorizontalLayout {
                            spacing: 8px;
                            Rectangle { width: 48px; height: 44px; border-radius: 8px; background: #e6eaf0;
                                Text { text: "-"; font-size: 22px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { clicked => { root.inc-line(root.selected-item, -1); } }
                            }
                            Rectangle { width: 48px; height: 44px; border-radius: 8px; background: #e6eaf0;
                                Text { text: "+"; font-size: 22px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { clicked => { root.inc-line(root.selected-item, 1); } }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            Rectangle { width: 110px; height: 44px; border-radius: 8px; background: #dc2626;
                                Text { text: "Annuler"; color: white; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { clicked => { root.modal-kind = "void"; } }
                            }
                        }
                        if root.selected-state == "SENT" : Rectangle {
                            height: 44px; border-radius: 8px; background: #7c3aed;
                            Text { text: "Offrir"; color: white; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked => { root.modal-kind = "comp"; } }
                        }

                        Rectangle { height: 1px; background: #c4ccd8; }
                        HorizontalLayout {
                            Text { text: "TOTAL"; font-size: 20px; font-weight: 800; horizontal-stretch: 1; vertical-alignment: center; }
                            Text { text: "\{root.total} \{root.currency}"; font-size: 22px; font-weight: 800; }
                        }

                        ActionBtn { label: "Envoyer en cuisine"; fill: #16a34a; enabled: root.can-send; clicked => { root.send(); } }
                        Rectangle {
                            height: 44px; border-radius: 10px; background: #e6eaf0;
                            Text { text: "Imprimer la facture"; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                            TouchArea { clicked => { root.print-facture(); } }
                        }
                        HorizontalLayout {
                            spacing: 10px;
                            ActionBtn { label: "Espèces"; fill: #16a34a; enabled: root.can-pay; clicked => { root.pay("Espèces"); } }
                            ActionBtn { label: "Portefeuille"; fill: #2563eb; enabled: root.can-pay; clicked => { root.pay("Portefeuille"); } }
                        }
                        if root.has-check : Rectangle {
                            height: 34px;
                            Text { text: "Clôturer impayé"; color: #6a7384; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked => { root.modal-kind = "unpaid"; } }
                        }
                        Text { text: root.status; color: #16a34a; horizontal-alignment: center; wrap: word-wrap; }
                    }
                }
            }
        }
    }

    // ===================== MODAL (server picker / reasons) =====================
    if root.modal-kind != "" : Rectangle {
        background: #00000088;
        TouchArea { clicked => { root.modal-kind = ""; } }
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 380px;
                    height: 460px;
                    background: white;
                    border-radius: 14px;
                    VerticalLayout {
                        padding: 18px;
                        spacing: 8px;
                        Text {
                            font-size: 18px; font-weight: 800;
                            text: root.modal-kind == "server" ? "Assigner un serveur"
                                : root.modal-kind == "void" ? "Annuler l'article"
                                : root.modal-kind == "comp" ? "Offrir l'article"
                                : "Clôturer la note impayée";
                        }
                        ScrollView {
                            vertical-stretch: 1;
                            VerticalLayout {
                                spacing: 6px;
                                if root.modal-kind == "server" : VerticalLayout {
                                    spacing: 6px;
                                    for s in root.servers : ReasonBtn { label: s.name; clicked => { root.pick-server(s.id); root.modal-kind = ""; } }
                                }
                                if root.modal-kind == "void" : VerticalLayout {
                                    spacing: 6px;
                                    for rz in root.void-reasons : ReasonBtn { label: rz.label; clicked => { root.apply-reason("void", root.selected-item, rz.id); root.modal-kind = ""; } }
                                }
                                if root.modal-kind == "comp" : VerticalLayout {
                                    spacing: 6px;
                                    for rz in root.comp-reasons : ReasonBtn { label: rz.label; clicked => { root.apply-reason("comp", root.selected-item, rz.id); root.modal-kind = ""; } }
                                }
                                if root.modal-kind == "unpaid" : VerticalLayout {
                                    spacing: 6px;
                                    for rz in root.unpaid-reasons : ReasonBtn { label: rz.label; clicked => { root.apply-reason("unpaid", root.selected-item, rz.id); root.modal-kind = ""; } }
                                }
                            }
                        }
                        Rectangle {
                            height: 44px; border-radius: 8px; background: #e6eaf0;
                            Text { text: "Fermer"; horizontal-alignment: center; vertical-alignment: center; font-weight: 700; }
                            TouchArea { clicked => { root.modal-kind = ""; } }
                        }
                    }
                }
            }
        }
    }
}
